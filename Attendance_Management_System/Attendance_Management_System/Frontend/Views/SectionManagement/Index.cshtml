@model Attendance_Management_System.Backend.ViewModels.Sections.SectionManagementIndexViewModel
@{
    ViewData["Title"] = "Sections";
}

<section class="panel">
    <h3>Section Management</h3>
    <p class="muted">Admin-only section CRUD and teacher assignment workflows.</p>

    @if (TempData["SectionsSuccess"] is string successMessage)
    {
        <p class="status-pill active">@successMessage</p>
    }

    @if (TempData["SectionsError"] is string errorMessage)
    {
        <p class="form-validation">@errorMessage</p>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="form-validation">@Model.ErrorMessage</p>
    }

    @if (!Model.IsAdmin)
    {
        <p class="footer-note">Section administration is only available to admins.</p>
        <p class="footer-note">
            Use <a asp-controller="Timetable" asp-action="Index">Timetable</a> and
            <a asp-controller="SectionAttendance" asp-action="Index">Attendance Checklist</a> for teaching workflows.
        </p>
    }
    else
    {
        <article class="panel">
            <h3>Create Section</h3>

            @if (!string.IsNullOrWhiteSpace(Model.CreateSectionOptionsErrorMessage))
            {
                <p class="form-validation">@Model.CreateSectionOptionsErrorMessage</p>
            }

            @if (!string.IsNullOrWhiteSpace(Model.TeacherOptionsErrorMessage))
            {
                <p class="form-validation">@Model.TeacherOptionsErrorMessage</p>
            }

            <form asp-controller="SectionManagement" asp-action="Create" method="post" class="filters-grid three">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                <div>
                    <label asp-for="CreateForm.Name"></label>
                    <input asp-for="CreateForm.Name" class="input-select" />
                    <span asp-validation-for="CreateForm.Name" class="field-validation"></span>
                </div>
                <div>
                    <label asp-for="CreateForm.YearLevel"></label>
                    <input asp-for="CreateForm.YearLevel" class="input-select" type="number" min="1" />
                    <p id="create-year-level-hint" class="field-helper compact">Choose a course to load the allowed
                        year-level range.</p>
                        <span asp-validation-for="CreateForm.YearLevel" class="field-validation"></span>
                    </div>
                    <div>
                        <label asp-for="CreateForm.AcademicYearId"></label>
                        <select asp-for="CreateForm.AcademicYearId" class="input-select">
                            <option value="">Choose academic period</option>
                            @foreach (var period in Model.AcademicPeriods)
                            {
                                <option value="@period.Id">@period.Label</option>
                            }
                        </select>
                        <span asp-validation-for="CreateForm.AcademicYearId" class="field-validation"></span>
                    </div>
                    <div>
                        <label asp-for="CreateForm.CourseId"></label>
                        <select asp-for="CreateForm.CourseId" class="input-select">
                            <option value="">Choose course</option>
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" data-min-year-level="@course.MinYearLevel"
                                        data-max-year-level="@course.MaxYearLevel"
                                        data-education-level-label="@course.EducationLevelLabel">
                                    @course.Label
                                </option>
                            }
                        </select>
                        <p class="field-helper compact">Choose the course first to unlock matching subjects.</p>
                        <span asp-validation-for="CreateForm.CourseId" class="field-validation"></span>
                    </div>
                    <div>
                        <label asp-for="CreateForm.SubjectId"></label>
                        <select asp-for="CreateForm.SubjectId" class="input-select">
                            <option value="">Choose course first</option>
                            @foreach (var subject in Model.Subjects)
                            {
                                <option value="@subject.Id" data-course-id="@subject.CourseId">@subject.Label</option>
                            }
                        </select>
                        <p class="field-helper compact">Only subjects under the selected course will appear.</p>
                        <span asp-validation-for="CreateForm.SubjectId" class="field-validation"></span>
                    </div>
                    <div>
                        <label asp-for="CreateForm.ClassroomId"></label>
                        <select asp-for="CreateForm.ClassroomId" class="input-select">
                            <option value="">Choose classroom</option>
                            @foreach (var classroom in Model.Classrooms)
                            {
                                <option value="@classroom.Id">@classroom.Label</option>
                            }
                        </select>
                        <span asp-validation-for="CreateForm.ClassroomId" class="field-validation"></span>
                    </div>

                    <button type="submit" class="btn-primary btn-inline">Create Section</button>
                </form>
            </article>

            @if (!Model.Sections.Any())
            {
                <p class="footer-note">No sections found.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Year</th>
                                <th>Course</th>
                                <th>Subject</th>
                                <th>Classroom</th>
                                <th>Enrolled</th>
                                <th>Teachers</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Sections)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.YearLevel</td>
                                    <td>@item.CourseName</td>
                                    <td>@item.SubjectName</td>
                                    <td>@item.ClassroomName</td>
                                    <td>@item.CurrentEnrollmentCount</td>
                                    <td>
                                        @if (!item.AssignedTeachers.Any())
                                        {
                                            <span class="muted">No teacher assigned</span>
                                        }
                                        else
                                        {
                                            <div class="teacher-chip-list">
                                                @foreach (var teacher in item.AssignedTeachers)
                                                {
                                                    <span class="teacher-chip" title="@teacher.Label">@teacher.ShortLabel</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div class="action-stack">
                                            <form asp-controller="SectionManagement" asp-action="Update" asp-route-id="@item.Id"
                                                  method="post" class="stack-form">
                                                @Html.AntiForgeryToken()
                                                <input type="text" name="UpdateForm.Name" value="@item.Name"
                                                       class="input-select compact-input" placeholder="Name" />
                                                <input type="number" name="UpdateForm.YearLevel" value="@item.YearLevel" min="1"
                                                       class="input-select compact-input" placeholder="Year" />
                                                <button type="submit" class="btn-secondary">Save</button>
                                            </form>

                                            <form asp-controller="SectionManagement" asp-action="AssignTeacher" asp-route-id="@item.Id"
                                                  method="post" class="stack-form">
                                                @Html.AntiForgeryToken()
                                                <select name="AssignForm.TeacherId" class="input-select compact-input"
                                                        disabled="@(!Model.TeacherOptions.Any())">
                                                    <option value="">Select teacher to assign</option>
                                                    @foreach (var teacher in Model.TeacherOptions)
                                                    {
                                                        <option value="@teacher.Id">@teacher.Label</option>
                                                    }
                                                </select>
                                                <p class="field-helper compact">Active teachers only.</p>
                                                <button type="submit" class="btn-secondary"
                                                        disabled="@(!Model.TeacherOptions.Any())">Assign Teacher</button>
                                            </form>

                                            <form asp-controller="SectionManagement" asp-action="RemoveTeacher" asp-route-id="@item.Id"
                                                  method="post" class="stack-form">
                                                @Html.AntiForgeryToken()
                                                <select name="teacherId" class="input-select compact-input"
                                                        disabled="@(!item.AssignedTeachers.Any())">
                                                    @if (!item.AssignedTeachers.Any())
                                                    {
                                                        <option value="">No assigned teacher</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="">Select assigned teacher</option>
                                                        @foreach (var teacher in item.AssignedTeachers)
                                                        {
                                                            <option value="@teacher.Id">@teacher.ShortLabel</option>
                                                        }
                                                    }
                                                </select>
                                                <p class="field-helper compact">Only teachers assigned to this section are listed.</p>
                                                <button type="submit" class="btn-secondary"
                                                        disabled="@(!item.AssignedTeachers.Any())">Remove Teacher</button>
                                            </form>

                                            <form asp-controller="SectionManagement" asp-action="Delete" asp-route-id="@item.Id"
                                                  method="post" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </section>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />

        <script>
            (() => {
                const courseSelect = document.getElementById("CreateForm_CourseId");
                const subjectSelect = document.getElementById("CreateForm_SubjectId");
                const yearLevelInput = document.getElementById("CreateForm_YearLevel");
                const yearLevelHint = document.getElementById("create-year-level-hint");

                if (!courseSelect || !subjectSelect) {
                    return;
                }

                const allSubjectOptions = Array.from(subjectSelect.options)
                    .filter(option => option.dataset.courseId);

                const createPlaceholderOption = (text) => {
                    const option = document.createElement("option");
                    option.value = "";
                    option.textContent = text;
                    return option;
                };

                const refreshSubjectOptions = () => {
                    const selectedCourseId = courseSelect.value;
                    const selectedSubjectId = subjectSelect.value;
                    const filteredOptions = allSubjectOptions
                        .filter(option => option.dataset.courseId === selectedCourseId);

                    subjectSelect.innerHTML = "";

                    if (selectedCourseId === "") {
                        subjectSelect.appendChild(createPlaceholderOption("Choose course first"));
                    } else if (filteredOptions.length === 0) {
                        subjectSelect.appendChild(createPlaceholderOption("No subjects available for this course"));
                    } else {
                        subjectSelect.appendChild(createPlaceholderOption("Choose subject"));
                        for (const option of filteredOptions) {
                            subjectSelect.appendChild(option);
                        }
                    }

                    const hasPreviousSelection = Array.from(subjectSelect.options)
                        .some(option => option.value === selectedSubjectId);

                    subjectSelect.value = hasPreviousSelection ? selectedSubjectId : "";
                    subjectSelect.disabled = selectedCourseId === "" || filteredOptions.length === 0;
                };

                const refreshYearLevelBounds = () => {
                    if (!yearLevelInput) {
                        return;
                    }

                    const selectedCourseOption = courseSelect.options[courseSelect.selectedIndex];
                    const minYearLevel = Number(selectedCourseOption?.dataset.minYearLevel ?? 1);
                    const maxYearLevel = Number(selectedCourseOption?.dataset.maxYearLevel ?? 12);
                    const levelLabel = selectedCourseOption?.dataset.educationLevelLabel || "Selected course";

                    yearLevelInput.min = String(minYearLevel);
                    yearLevelInput.max = String(maxYearLevel);

                    const parsedValue = Number(yearLevelInput.value || "0");
                    if (!yearLevelInput.value || Number.isNaN(parsedValue) || parsedValue < minYearLevel || parsedValue > maxYearLevel) {
                        yearLevelInput.value = String(minYearLevel);
                    }

                    if (yearLevelHint) {
                        yearLevelHint.textContent = `${levelLabel} allows year levels ${minYearLevel}-${maxYearLevel}.`;
                    }
                };

                courseSelect.addEventListener("change", () => {
                    refreshSubjectOptions();
                    refreshYearLevelBounds();
                });
                refreshSubjectOptions();
                refreshYearLevelBounds();
            })();
        </script>
    }
