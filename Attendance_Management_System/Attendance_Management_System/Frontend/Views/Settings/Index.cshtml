@model Attendance_Management_System.Backend.ViewModels.Settings.SettingsIndexViewModel
@{
    ViewData["Title"] = "Settings";
}

<section class="panel">
    <h3>Settings</h3>
    <p class="muted">Account profile details from current sign-in identity.</p>

    <div class="info-grid">
        <article class="info-card">
            <span class="muted">Username</span>
            <strong>@Model.Username</strong>
        </article>
        <article class="info-card">
            <span class="muted">Email</span>
            <strong>@Model.Email</strong>
        </article>
        <article class="info-card">
            <span class="muted">Full Name</span>
            <strong>@Model.FullName</strong>
        </article>
        <article class="info-card">
            <span class="muted">Role</span>
            <strong>@Model.Role</strong>
        </article>
    </div>

    <p class="footer-note">Password change UI is deferred in this frontend-only slice because the backend API contract for changing password is not currently exposed in this project.</p>
</section>
