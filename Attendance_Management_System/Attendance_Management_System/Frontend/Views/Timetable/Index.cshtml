@model Attendance_Management_System.Backend.ViewModels.Sections.TimetableIndexViewModel
@{
    ViewData["Title"] = "Timetable";
    var dayHeaders = new[]
    {
        (Key: 1, Name: "Monday"),
        (Key: 2, Name: "Tuesday"),
        (Key: 3, Name: "Wednesday"),
        (Key: 4, Name: "Thursday"),
        (Key: 5, Name: "Friday"),
        (Key: 6, Name: "Saturday"),
        (Key: 0, Name: "Sunday")
    };
}

<section class="panel">
    <h3>Section Timetable</h3>
    <p class="muted">Weekly timetable from 5:00 AM to 7:00 PM. Teachers can view all slots and manage only their own
        slots.</p>

        @if (TempData["TimetableSuccess"] is string successMessage)
        {
            <p class="status-pill active">@successMessage</p>
        }

        @if (TempData["TimetableError"] is string errorMessage)
        {
            <p class="form-validation">@errorMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="form-validation">@Model.ErrorMessage</p>
        }
        else
        {
            <form method="get" class="filters-grid">
                <div>
                    <label for="sectionId">Section</label>
                    <select id="sectionId" name="sectionId" class="input-select">
                        @foreach (var sectionOption in Model.SectionOptions)
                        {
                            <option value="@sectionOption.Id" selected="@(Model.SelectedSectionId == sectionOption.Id)">
                                @sectionOption.Name
                            </option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn-primary btn-inline">Load Timetable</button>
            </form>

            @if (Model.SelectedSectionId.HasValue)
            {
                <p class="footer-note">
                    Section: <strong>@Model.SelectedSectionName</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedSectionSubjectName))
                    {
                        <span> | Primary Subject: <strong>@Model.SelectedSectionSubjectName</strong></span>
                    }
                </p>

                @if (Model.IsTeacher)
                {
                    @if (Model.IsCurrentTeacherAssignedToSelectedSection)
                    {
                        <form asp-controller="Timetable" asp-action="SelfUnassignTeacher" asp-route-id="@Model.SelectedSectionId"
                              method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedSectionId" value="@Model.SelectedSectionId" />
                            <button type="submit" class="btn-secondary btn-xs">Unassign Myself From Section</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Timetable" asp-action="SelfAssignTeacher" asp-route-id="@Model.SelectedSectionId"
                              method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedSectionId" value="@Model.SelectedSectionId" />
                            <button type="submit" class="btn-secondary btn-xs">Assign Myself to Section</button>
                        </form>
                    }
                }
            }

            @if (!string.IsNullOrWhiteSpace(Model.TimetableSubjectsErrorMessage))
            {
                <p class="form-validation">@Model.TimetableSubjectsErrorMessage</p>
            }

            @if (!string.IsNullOrWhiteSpace(Model.TimetableErrorMessage))
            {
                <p class="form-validation">@Model.TimetableErrorMessage</p>
            }
            else if (!Model.TimetableRows.Any())
            {
                <p class="footer-note">No timetable data available for the selected section.</p>
            }
            else
            {
                <div class="timetable-wrap">
                    <table class="timetable-table">
                        <thead>
                            <tr>
                                <th class="time-header">Time</th>
                                @foreach (var day in dayHeaders)
                                {
                                    <th>@day.Name</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.TimetableRows)
                            {
                                <tr>
                                    <th class="time-label">@row.TimeLabel</th>
                                    @foreach (var cell in row.Cells)
                                    {
                                        <td class="timetable-cell">
                                            @if (cell.IsOccupied)
                                            {
                                                <article class="slot-card @(cell.IsMine ? "slot-mine" : "slot-view")">
                                                    @if (cell.IsStart)
                                                    {
                                                        <p class="slot-subject">@cell.SubjectName</p>
                                                        <p class="slot-teacher">@cell.TeacherName</p>
                                                        <p class="slot-time">@cell.TimeRange</p>

                                                        @if (Model.IsTeacher && cell.IsMine && cell.ScheduleId.HasValue)
                                                        {
                                                            <div class="slot-actions">
                                                                <details class="slot-edit-details">
                                                                    <summary class="btn-secondary btn-xs">Edit</summary>
                                                                    <form asp-controller="Timetable" asp-action="UpdateTimetableSlot"
                                                                          asp-route-scheduleId="@cell.ScheduleId" method="post" class="stack-form">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="selectedSectionId"
                                                                               value="@Model.SelectedSectionId" />
                                                                        <label for="subject-@cell.ScheduleId">Subject</label>
                                                                        <select id="subject-@cell.ScheduleId" name="subjectId"
                                                                                class="input-select compact-input" required>
                                                                            @if (Model.TimetableSubjects.Any())
                                                                            {
                                                                                @foreach (var subjectOption in Model.TimetableSubjects)
                                                                                {
                                                                                    <option value="@subjectOption.Id"
                                                                                            selected="@(subjectOption.Id == cell.SubjectId)">@subjectOption.Label
                                                                                    </option>
                                                                                }

                                                                                @if (!Model.TimetableSubjects.Any(subjectOption => subjectOption.Id ==
                                                                                                                            cell.SubjectId))
                                                                                {
                                                                                    <option value="@cell.SubjectId" selected>@cell.SubjectName (Current)
                                                                                    </option>
                                                                                }
                                                                            }
                                                                            else
                                                                            {
                                                                                <option value="@cell.SubjectId">@cell.SubjectName</option>
                                                                            }
                                                                        </select>
                                                                        <label for="day-@cell.ScheduleId">Day</label>
                                                                        <select id="day-@cell.ScheduleId" name="dayOfWeek"
                                                                                class="input-select compact-input">
                                                                            @foreach (var day in dayHeaders)
                                                                            {
                                                                                <option value="@day.Key" selected="@(day.Key == cell.DayOfWeek)">@day.Name
                                                                                </option>
                                                                            }
                                                                        </select>
                                                                        <label for="start-@cell.ScheduleId">Start</label>
                                                                        <input id="start-@cell.ScheduleId" type="time" name="startTime"
                                                                               value="@cell.StartTime" class="input-select compact-input" />
                                                                        <label for="end-@cell.ScheduleId">End</label>
                                                                        <input id="end-@cell.ScheduleId" type="time" name="endTime"
                                                                               value="@cell.EndTime" class="input-select compact-input" />
                                                                        <button type="submit" class="btn-secondary btn-xs">Save</button>
                                                                    </form>
                                                                </details>

                                                                <form asp-controller="Timetable" asp-action="DeleteTimetableSlot"
                                                                      asp-route-scheduleId="@cell.ScheduleId" method="post" class="inline-form">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="selectedSectionId" value="@Model.SelectedSectionId" />
                                                                    <button type="submit" class="btn-danger btn-xs">Delete</button>
                                                                </form>
                                                            </div>
                                                        }
                                                        else if (!cell.IsMine)
                                                        {
                                                            <p class="slot-note">View only</p>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <p class="slot-subject">@cell.SubjectName</p>
                                                        <p class="slot-teacher">@cell.TeacherName</p>
                                                        <p class="slot-time">@cell.TimeRange</p>
                                                    }
                                                </article>
                                            }
                                            else if (Model.IsTeacher && Model.SelectedSectionId.HasValue)
                                            {
                                                <div class="slot-create-form">
                                                    <button type="button" class="btn-secondary btn-xs" data-quick-add-trigger="true"
                                                            data-section-id="@Model.SelectedSectionId" data-day-of-week="@cell.DayOfWeek"
                                                            data-day-name="@cell.DayName" data-start-time="@row.StartTime"
                                                            data-default-end-time="@row.EndTime" disabled="@(!Model.TimetableSubjects.Any())">
                                                        Add
                                                    </button>

                                                    @if (!Model.TimetableSubjects.Any())
                                                    {
                                                        <p class="slot-note">No subjects available.</p>
                                                    }

                                                    <noscript>
                                                        <form asp-controller="Timetable" asp-action="AddTimetableSlot" method="post"
                                                              class="stack-form">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="sectionId" value="@Model.SelectedSectionId" />
                                                            <input type="hidden" name="selectedSectionId" value="@Model.SelectedSectionId" />
                                                            <label>Subject</label>
                                                            <select name="subjectId" class="input-select compact-input" required
                                                                    disabled="@(!Model.TimetableSubjects.Any())">
                                                                @if (!Model.TimetableSubjects.Any())
                                                                {
                                                                    <option value="">No subjects available</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="">Choose subject</option>
                                                                    @foreach (var subjectOption in Model.TimetableSubjects)
                                                                    {
                                                                        <option value="@subjectOption.Id">@subjectOption.Label</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <input type="hidden" name="dayOfWeek" value="@cell.DayOfWeek" />
                                                            <input type="hidden" name="startTime" value="@row.StartTime" />
                                                            <input type="hidden" name="endTime" value="@row.EndTime" />
                                                            <button type="submit" class="btn-secondary btn-xs"
                                                                    disabled="@(!Model.TimetableSubjects.Any())">Add 30m</button>
                                                        </form>
                                                    </noscript>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="muted">-</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.IsTeacher && Model.SelectedSectionId.HasValue)
                {
                    <div id="quick-add-panel" class="quick-add-panel" hidden>
                        <article class="quick-add-card">
                            <div class="quick-add-header">
                                <h4>Quick Add Timetable Slot</h4>
                                <button type="button" class="btn-secondary btn-xs quick-add-close"
                                        data-quick-add-close="true">Close</button>
                            </div>

                            <p id="quick-add-hint" class="footer-note">Select a subject, end time, and optional repeat days.</p>

                            <form asp-controller="Timetable" asp-action="AddTimetableSlotRange" method="post" class="stack-form"
                                  id="quick-add-form">
                                @Html.AntiForgeryToken()

                                <input type="hidden" id="quick-add-section-id" name="sectionId" value="@Model.SelectedSectionId" />
                                <input type="hidden" name="selectedSectionId" value="@Model.SelectedSectionId" />

                                <div class="quick-add-grid">
                                    <div>
                                        <label for="quick-add-subject-id">Subject</label>
                                        <select id="quick-add-subject-id" name="subjectId" class="input-select compact-input" required>
                                            @if (!Model.TimetableSubjects.Any())
                                            {
                                                <option value="">No subjects available</option>
                                            }
                                            else
                                            {
                                                <option value="">Choose subject</option>
                                                @foreach (var subjectOption in Model.TimetableSubjects)
                                                {
                                                    <option value="@subjectOption.Id">@subjectOption.Label</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div>
                                        <label for="quick-add-start-time">Start</label>
                                        <input id="quick-add-start-time" type="time" name="startTime" class="input-select compact-input"
                                               readonly />
                                    </div>
                                    <div>
                                        <label for="quick-add-end-time">End</label>
                                        <input id="quick-add-end-time" type="time" name="endTime" class="input-select compact-input"
                                               step="1800" required />
                                    </div>
                                </div>

                                <fieldset class="quick-add-days">
                                    <legend>Repeat Days</legend>
                                    <p class="muted quick-add-days-note">The clicked day is selected by default.</p>
                                    <div class="quick-add-days-list">
                                        @foreach (var day in dayHeaders)
                                        {
                                            var dayId = $"quick-add-day-{day.Key}";
                                            <label class="quick-add-day-item" for="@dayId">
                                                <input id="@dayId" type="checkbox" name="selectedDays" value="@day.Key" />
                                                <span>@day.Name</span>
                                            </label>
                                        }
                                    </div>
                                </fieldset>

                                <div class="quick-add-actions">
                                    <button type="submit" class="btn-primary btn-inline"
                                            disabled="@(!Model.TimetableSubjects.Any())">Add Slot(s)</button>
                                    <button type="button" class="btn-secondary btn-inline" data-quick-add-close="true">Cancel</button>
                                </div>
                            </form>
                        </article>
                    </div>
                }
            }
        }
    </section>
