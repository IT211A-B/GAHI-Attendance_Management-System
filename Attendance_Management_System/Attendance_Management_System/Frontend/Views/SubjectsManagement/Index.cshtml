@model Attendance_Management_System.Backend.ViewModels.Subjects.SubjectsIndexViewModel
@{
    ViewData["Title"] = "Subjects";
}

<section class="panel">
    <h3>Subjects</h3>
    <p class="muted">Server-rendered C# MVC subject CRUD workflows.</p>

    @if (TempData["SubjectsSuccess"] is string successMessage)
    {
        <p class="status-pill active">@successMessage</p>
    }

    @if (TempData["SubjectsError"] is string errorMessage)
    {
        <p class="form-validation">@errorMessage</p>
    }

    <article class="panel">
        <h3>Create Subject</h3>
        <form asp-controller="SubjectsManagement" asp-action="Create" method="post" class="filters-grid three">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-validation"></div>

            <div>
                <label asp-for="CreateForm.Name"></label>
                <input asp-for="CreateForm.Name" class="input-select" />
                <span asp-validation-for="CreateForm.Name" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Code"></label>
                <input asp-for="CreateForm.Code" class="input-select" />
                <span asp-validation-for="CreateForm.Code" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.CourseId"></label>
                <input asp-for="CreateForm.CourseId" class="input-select" type="number" min="1" />
                <span asp-validation-for="CreateForm.CourseId" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Units"></label>
                <input asp-for="CreateForm.Units" class="input-select" type="number" min="1" />
                <span asp-validation-for="CreateForm.Units" class="field-validation"></span>
            </div>

            <button type="submit" class="btn-primary btn-inline">Create Subject</button>
        </form>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="form-validation">@Model.ErrorMessage</p>
    }
    else if (!Model.Subjects.Any())
    {
        <p class="footer-note">No subjects found.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="app-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Course</th>
                        <th>Units</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Subjects)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td><span class="role-pill">@item.Code</span></td>
                            <td>@item.CourseName</td>
                            <td>@item.Units</td>
                            <td>
                                <div class="action-stack">
                                    <form asp-controller="SubjectsManagement" asp-action="Update" asp-route-id="@item.Id"
                                          method="post" class="stack-form">
                                        @Html.AntiForgeryToken()
                                        <input type="text" name="UpdateForm.Name" value="@item.Name"
                                               class="input-select compact-input" placeholder="Name" />
                                        <input type="text" name="UpdateForm.Code" value="@item.Code"
                                               class="input-select compact-input" placeholder="Code" />
                                        <input type="number" name="UpdateForm.CourseId" value="@item.CourseId" min="1"
                                               class="input-select compact-input" placeholder="Course ID" />
                                        <input type="number" name="UpdateForm.Units" value="@item.Units" min="1"
                                               class="input-select compact-input" placeholder="Units" />
                                        <button type="submit" class="btn-secondary">Save</button>
                                    </form>
                                    <form asp-controller="SubjectsManagement" asp-action="Delete" asp-route-id="@item.Id"
                                          method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
