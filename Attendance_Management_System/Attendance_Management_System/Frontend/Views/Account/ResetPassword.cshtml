@model Attendance_Management_System.Backend.ViewModels.Auth.ResetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Reset password";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DonBosco AMS</title>
    <link rel="icon" type="image/png" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="auth-page">
    <main class="auth-wrapper">
        <section class="auth-hero">
            <p class="auth-chip">Account Recovery</p>
            <h1>Set a new account password</h1>
            <p class="auth-lead">Create a strong new password to regain secure access to your account.</p>
            <ul class="auth-values" aria-label="Password reset reminders">
                <li>Minimum 8 Characters</li>
                <li>One-Time Token Validation</li>
                <li>Secure Password Update</li>
            </ul>
            <figure class="auth-hero-media" aria-hidden="true">
                <app-lazy-image src="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
                                alt="Don Bosco Technical College logo"></app-lazy-image>
            </figure>
        </section>

        <section class="auth-card" aria-label="Reset password form">
            <h2>Reset password</h2>

            <form asp-action="ResetPassword" method="post" class="auth-form">
                <input asp-for="UserId" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="field-validation"></span>

                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation"></span>

                <button type="submit" class="btn-primary">Reset password</button>

                <p class="auth-alt-action">
                    Return to
                    <a asp-action="Login">sign in</a>
                </p>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
</body>

</html>
