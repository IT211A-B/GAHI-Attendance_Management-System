@model Attendance_Management_System.Backend.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DonBosco AMS</title>
    @* Login also declares favicon because this page uses Layout = null. *@
    <link rel="icon" type="image/png" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <main class="auth-wrapper">
        @* Hero section communicates mission and values before authentication. *@
        <section class="auth-hero">
            <p class="auth-chip">Don Bosco Technical College - Cebu</p>
            <h1>Attendance intelligence rooted in Bosconian values</h1>
            <p class="auth-lead">Welcome back. Sign in to record every class with accuracy, respond early to attendance risks, and support each learner with faith, reason, and loving-kindness.</p>
            <ul class="auth-values" aria-label="Bosconian values">
                <li>Faith-Centered</li>
                <li>Excellence</li>
                <li>Integrity</li>
                <li>Compassion</li>
                <li>Service</li>
            </ul>
            <figure class="auth-hero-media" aria-hidden="true">
                <img src="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png" alt="Don Bosco Technical College logo" />
            </figure>
        </section>

        <section class="auth-card" aria-label="Login form">
            <h2>Sign in</h2>

            @* ASP.NET Tag Helpers bind form post and model fields directly to backend view model properties. *@
            <form asp-action="Login" method="post" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation"></span>

                <label asp-for="Password"></label>
                <input asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation"></span>

                <label class="checkbox-row">
                    <input asp-for="RememberMe" />
                    <span>Keep me signed in on this device</span>
                </label>

                <button type="submit" class="btn-primary">Sign in</button>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    @* site.js contains frontend motion and page-level interaction hooks. *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>