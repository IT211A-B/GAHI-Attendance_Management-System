@model Attendance_Management_System.Backend.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DonBosco AMS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <main class="auth-wrapper">
        <section class="auth-hero">
            <p class="auth-chip">DonBosco Attendance Management System</p>
            <h1>Attendance Monitoring, Simplified</h1>
            <p>Welcome back. Sign in to continue with the C# MVC frontend while retaining your previous design language.</p>
        </section>

        <section class="auth-card" aria-label="Login form">
            <h2>Sign in</h2>

            <form asp-action="Login" method="post" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation"></span>

                <label asp-for="Password"></label>
                <input asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation"></span>

                <label class="checkbox-row">
                    <input asp-for="RememberMe" />
                    <span>Keep me signed in on this device</span>
                </label>

                <button type="submit" class="btn-primary">Sign in</button>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>