@model Attendance_Management_System.Backend.ViewModels.Auth.StudentSignupViewModel
@{
    Layout = null;
    ViewData["Title"] = "Student sign up";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DonBosco AMS</title>
    <link rel="icon" type="image/png" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="auth-page">
    <main class="auth-wrapper">
        <section class="auth-hero">
            <p class="auth-chip">Student Enrollment Signup</p>
            <h1>Create your student account and submit your enrollment request</h1>
            <p class="auth-lead">Use this form if you do not have an account yet. Once submitted, your enrollment will
                be marked pending and reviewed by administration. Section placement is assigned automatically based on
                your course, intake period, and available capacity.</p>
                <ul class="auth-values" aria-label="Enrollment flow highlights">
                    <li>Account Creation</li>
                    <li>Student Profile</li>
                    <li>Pending Approval</li>
                    <li>Secure Submission</li>
                </ul>
                <figure class="auth-hero-media" aria-hidden="true">
                    <app-lazy-image src="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
                                    alt="Don Bosco Technical College logo"></app-lazy-image>
                </figure>
            </section>

            <section class="auth-card signup-card" aria-label="Signup form">
                <h2>Student sign up</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <p class="form-validation">@Model.ErrorMessage</p>
                }

                <form asp-action="Signup" method="post" class="auth-form auth-form-grid">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                    <div class="auth-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="StudentNumber"></label>
                        <input asp-for="StudentNumber" autocomplete="off" />
                        <span asp-validation-for="StudentNumber" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Password"></label>
                        <input asp-for="Password" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="ConfirmPassword"></label>
                        <input asp-for="ConfirmPassword" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="MiddleName"></label>
                        <input asp-for="MiddleName" autocomplete="additional-name" />
                        <span asp-validation-for="MiddleName" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Birthdate"></label>
                        <input asp-for="Birthdate" type="date" />
                        <span asp-validation-for="Birthdate" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Gender"></label>
                        <select asp-for="Gender">
                            <option value="">Choose a gender</option>
                            <option value="M">M</option>
                            <option value="F">F</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="GuardianName"></label>
                        <input asp-for="GuardianName" autocomplete="name" />
                        <span asp-validation-for="GuardianName" class="field-validation"></span>
                    </div>

                    <div class="auth-field auth-field-wide">
                        <label asp-for="Address"></label>
                        <textarea asp-for="Address" rows="2"></textarea>
                        <span asp-validation-for="Address" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="GuardianContact"></label>
                        <input asp-for="GuardianContact" autocomplete="tel" />
                        <span asp-validation-for="GuardianContact" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="CourseId"></label>
                        <select asp-for="CourseId" id="signup-course-id">
                            <option value="">Choose a course</option>
                            @foreach (var course in Model.AvailableCourses)
                            {
                                <option value="@course.Id">@course.Label</option>
                            }
                        </select>
                        <span asp-validation-for="CourseId" class="field-validation"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="AcademicYearId"></label>
                        <select asp-for="AcademicYearId">
                            <option value="">Choose an academic period</option>
                            @foreach (var period in Model.AvailableAcademicYears)
                            {
                                <option value="@period.Id">@period.Label</option>
                            }
                        </select>
                        <span asp-validation-for="AcademicYearId" class="field-validation"></span>
                    </div>

                    <button type="submit" class="btn-primary">Create account and request enrollment</button>

                    <p class="auth-helper">Your request will be submitted as pending and reviewed by administration. A
                        section will be assigned automatically.</p>

                        <p class="auth-alt-action">
                            Already have an account?
                            <a asp-action="Login">Sign in</a>
                        </p>
                    </form>
                </section>
            </main>

            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
            <script src="~/js/site.js" asp-append-version="true"></script>
            <partial name="_ValidationScriptsPartial" />
        </body>

    </html>