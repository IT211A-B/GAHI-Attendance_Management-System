@model Attendance_Management_System.Backend.ViewModels.Auth.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot password";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DonBosco AMS</title>
    <link rel="icon" type="image/png" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
          asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="auth-page">
    <main class="auth-wrapper">
        <section class="auth-hero">
            <p class="auth-chip">Account Recovery</p>
            <h1>Recover access to your account</h1>
            <p class="auth-lead">Enter your account email and we will send a secure password reset link if your account
                exists.</p>
                <ul class="auth-values" aria-label="Password reset reminders">
                    <li>Secure Reset Token</li>
                    <li>Time-Limited Link</li>
                    <li>Protected Submission</li>
                </ul>
                <figure class="auth-hero-media" aria-hidden="true">
                    <app-lazy-image src="~/images/Gemini_Generated_Image_s4on5ys4on5ys4on-Photoroom.png"
                                    alt="Don Bosco Technical College logo"></app-lazy-image>
                </figure>
            </section>

            <section class="auth-card" aria-label="Forgot password form">
                <h2>Forgot password</h2>

                @if (TempData["AuthSuccess"] is string successMessage)
                {
                    <p class="status-pill active">@successMessage</p>
                }

                <form asp-action="ForgotPassword" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="form-validation"></div>

                    <label asp-for="Email"></label>
                    <input asp-for="Email" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-validation"></span>

                    <button type="submit" class="btn-primary">Send reset instructions</button>

                    <p class="auth-alt-action">
                        Remembered your password?
                        <a asp-action="Login">Back to sign in</a>
                    </p>
                </form>
            </section>
        </main>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        <partial name="_ValidationScriptsPartial" />
    </body>

</html>
