@model Attendance_Management_System.Backend.ViewModels.Frontend.StaffPageViewModel
@{
    ViewData["Title"] = "Staff";
}

<section class="panel">
    <h3>Staff Operations</h3>
    <p class="muted">Administrative staffing overview rendered directly in MVC.</p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="form-validation">@Model.ErrorMessage</p>
    }
    else
    {
        <section class="grid-4 compact-gap">
            <article class="stat-card">
                <p class="stat-title">Active Teachers</p>
                <p class="stat-value success">@Model.ActiveTeachers</p>
            </article>
            <article class="stat-card">
                <p class="stat-title">Inactive Teachers</p>
                <p class="stat-value warning">@Model.InactiveTeachers</p>
            </article>
            <article class="stat-card">
                <p class="stat-title">Active Admins</p>
                <p class="stat-value">@Model.ActiveAdmins</p>
            </article>
            <article class="stat-card">
                <p class="stat-title">Active Students</p>
                <p class="stat-value">@Model.ActiveStudents</p>
            </article>
        </section>

        <article class="panel">
            <h3>Teachers</h3>
            @if (!Model.Teachers.Any())
            {
                <p class="footer-note">No teacher records found.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Department</th>
                                <th>Sections</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var teacher in Model.Teachers)
                            {
                                <tr>
                                    <td>@teacher.Name</td>
                                    <td>@teacher.Email</td>
                                    <td>@teacher.Department</td>
                                    <td>@teacher.SectionsText</td>
                                    <td>
                                        @if (teacher.IsActive)
                                        {
                                            <span class="status-pill active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill inactive">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="panel">
            <h3>Administrator Accounts</h3>
            @if (!Model.Admins.Any())
            {
                <p class="footer-note">No administrator accounts found.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table class="app-table">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>Email</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in Model.Admins)
                            {
                                <tr>
                                    <td>@admin.Id</td>
                                    <td>@admin.Email</td>
                                    <td>
                                        @if (admin.IsActive)
                                        {
                                            <span class="status-pill active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill inactive">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    }
</section>
