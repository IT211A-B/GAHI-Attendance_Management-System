@model Attendance_Management_System.Backend.ViewModels.Frontend.BusinessRulesPageViewModel
@{
    ViewData["Title"] = "Business Rules";
}

<section class="panel">
    <h3>Business Rules</h3>
    <p class="muted">Current operational rules sourced from server configuration.</p>

    <section class="grid-2">
        <article class="panel">
            <h3>Enrollment Capacity</h3>
            <ul class="list">
                <li><strong>Warning Threshold:</strong> @Model.WarningThreshold students</li>
                <li><strong>Over-Capacity Limit:</strong> @Model.OverCapacityLimit students</li>
                <li><strong>Auto Create Sections:</strong> @(Model.AutoCreateSections ? "Enabled" : "Disabled")</li>
            </ul>
        </article>

        <article class="panel">
            <h3>Authentication Session</h3>
            <ul class="list">
                <li><strong>Cookie Expiration:</strong> @Model.CookieExpirationHours hours</li>
                <li><strong>Sliding Expiration:</strong> @(Model.SlidingExpiration ? "Enabled" : "Disabled")</li>
                <li><strong>SameSite:</strong> @Model.SameSite</li>
                <li><strong>Secure Policy:</strong> @Model.SecurePolicy</li>
            </ul>
        </article>
    </section>

    <article class="panel">
        <h3>Policy Notes</h3>
        <ul class="list">
            <li>Enrollment approval and rejection are restricted to administrator workflows.</li>
            <li>Attendance marking is limited to authorized teaching context or admin override.</li>
            <li>Sections cannot be assigned beyond the configured over-capacity limit.</li>
            <li>All write flows use anti-forgery tokens and Post-Redirect-Get behavior.</li>
        </ul>
    </article>
</section>
