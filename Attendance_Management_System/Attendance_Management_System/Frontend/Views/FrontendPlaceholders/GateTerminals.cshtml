@model Attendance_Management_System.Backend.ViewModels.Frontend.GateTerminalsPageViewModel
@{
    ViewData["Title"] = "Gate Terminals";
}

<section class="panel">
    <h3>Gate Terminals</h3>
    <p class="muted">Operational snapshot for attendance intake points and schedule load.</p>

    <section class="grid-4 compact-gap">
        <article class="stat-card">
            <p class="stat-title">Scans Today</p>
            <p class="stat-value">@Model.TodayAttendanceScans</p>
        </article>
        <article class="stat-card">
            <p class="stat-title">Active Sections</p>
            <p class="stat-value">@Model.ActiveSections</p>
        </article>
        <article class="stat-card">
            <p class="stat-title">Schedules Today</p>
            <p class="stat-value">@Model.ActiveSchedulesToday</p>
        </article>
        <article class="stat-card">
            <p class="stat-title">Terminal Health</p>
            <p class="stat-value success">Online</p>
        </article>
    </section>

    <article class="panel">
        <h3>Integration Checklist</h3>
        <ul class="list">
            <li>Attendance ingest API is active for schedule-based marking.</li>
            <li>Teacher and admin dashboards can monitor scan throughput in real time.</li>
            <li>Dedicated hardware-terminal entity mapping is planned for the next backend increment.</li>
        </ul>
    </article>
</section>
