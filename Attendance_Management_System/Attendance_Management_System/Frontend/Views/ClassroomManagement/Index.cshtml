@model Attendance_Management_System.Backend.ViewModels.Classrooms.ClassroomsIndexViewModel
@{
    ViewData["Title"] = "Classrooms";
}

<section class="panel">
    <h3>Classroom Management</h3>
    <p class="muted">Server-rendered C# MVC classroom CRUD operations.</p>

    @if (TempData["ClassroomsSuccess"] is string successMessage)
    {
        <p class="status-pill active">@successMessage</p>
    }

    @if (TempData["ClassroomsError"] is string errorMessage)
    {
        <p class="form-validation">@errorMessage</p>
    }

    <article class="panel">
        <h3>Create Classroom</h3>
        <form asp-controller="ClassroomManagement" asp-action="Create" method="post" class="filters-grid">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="form-validation"></div>

            <div>
                <label asp-for="CreateForm.Name"></label>
                <input asp-for="CreateForm.Name" class="input-select" />
                <span asp-validation-for="CreateForm.Name" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Description"></label>
                <input asp-for="CreateForm.Description" class="input-select" />
                <span asp-validation-for="CreateForm.Description" class="field-validation"></span>
            </div>
            <button type="submit" class="btn-primary btn-inline">Create Classroom</button>
        </form>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="form-validation">@Model.ErrorMessage</p>
    }
    else if (!Model.Classrooms.Any())
    {
        <p class="footer-note">No classrooms found.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="app-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Classrooms)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td>
                            <div class="action-stack">
                                <form asp-controller="ClassroomManagement" asp-action="Update" asp-route-id="@item.Id" method="post" class="stack-form">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="UpdateForm.Name" value="@item.Name" class="input-select compact-input" placeholder="Name" />
                                    <input type="text" name="UpdateForm.Description" value="@(item.Description == "-" ? string.Empty : item.Description)" class="input-select compact-input" placeholder="Description" />
                                    <button type="submit" class="btn-secondary">Save</button>
                                </form>
                                <form asp-controller="ClassroomManagement" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}