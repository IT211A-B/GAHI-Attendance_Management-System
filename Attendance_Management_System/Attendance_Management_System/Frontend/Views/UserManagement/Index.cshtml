@model Attendance_Management_System.Backend.ViewModels.Users.UsersIndexViewModel
@{
    ViewData["Title"] = "Users";
}

<section class="panel">
    <h3>User Management</h3>
    <p class="muted">Server-rendered C# MVC user administration with form-based write actions.</p>

    @if (TempData["UsersSuccess"] is string successMessage)
    {
        <p class="status-pill active">@successMessage</p>
    }

    @if (TempData["UsersError"] is string errorMessage)
    {
        <p class="form-validation">@errorMessage</p>
    }

    <article class="panel">
        <h3>Create User</h3>
        <form asp-controller="UserManagement" asp-action="Create" method="post" class="filters-grid three">
            @Html.AntiForgeryToken()
            <div>
                <label asp-for="CreateForm.Email"></label>
                <input asp-for="CreateForm.Email" class="input-select" autocomplete="email" />
                <span asp-validation-for="CreateForm.Email" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Password"></label>
                <input asp-for="CreateForm.Password" class="input-select" autocomplete="new-password" />
                <span asp-validation-for="CreateForm.Password" class="field-validation"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Role"></label>
                <select asp-for="CreateForm.Role" class="input-select">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <span asp-validation-for="CreateForm.Role" class="field-validation"></span>
            </div>
            <button type="submit" class="btn-primary btn-inline">Create User</button>
        </form>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="form-validation">@Model.ErrorMessage</p>
    }
    else if (!Model.Users.Any())
    {
        <p class="footer-note">No users found.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="app-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Email</td>
                        <td><span class="role-pill">@user.Role</span></td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="status-pill active">Active</span>
                            }
                            else
                            {
                                <span class="status-pill inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <form asp-controller="UserManagement" asp-action="SetStatus" asp-route-id="@user.Id" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="isActive" value="@(!user.IsActive)" />
                                @if (user.IsActive)
                                {
                                    <button type="submit" class="btn-secondary">Deactivate</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn-primary">Activate</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}